# ──────────────────────────────────────────────────────
#  Taraa Backend — Environment Template
#  Copy to .env.development / .env.staging / .env.production
#  and fill in real values. Never commit files with secrets.
#
#  Database naming convention (same Atlas cluster, isolated databases):
#    development → taraa_dev
#    staging     → taraa_staging
#    production  → taraa_prod
# ──────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ── MongoDB Atlas ──────────────────────────────────────
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# dbname = taraa_dev | taraa_staging | taraa_prod
MONGODB_URI=
MONGODB_DB_NAME=taraa_dev

# ── JWT ────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── Cloudinary ─────────────────────────────────────────
# https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay ───────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ for dev/staging, rzp_live_ for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# https://dashboard.razorpay.com → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# ── Firebase Admin SDK ─────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Firebase Web Client Config ─────────────────────────
# Firebase Console → Project Settings → Your apps → Web app → SDK setup
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000

# ── Nodemailer (SMTP) ──────────────────────────────────
# dev/staging: Gmail App Password — myaccount.google.com/apppasswords
# production: SendGrid — host=smtp.sendgrid.net user=apikey pass=SG.xxx
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Taraa
MAIL_FROM_ADDRESS=noreply@taraa.in

# ── Firebase Cloud Messaging ───────────────────────────
FIREBASE_VAPID_PUBLIC_KEY=

# ── CORS ───────────────────────────────────────────────
# dev: http://localhost:3000
# staging: https://staging.taraa.in
# prod: https://taraa.in,https://www.taraa.in
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────
# dev: 100  staging: 60  prod: 30
THROTTLE_TTL=60
THROTTLE_LIMIT=60
