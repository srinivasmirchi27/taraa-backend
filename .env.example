# ──────────────────────────────────────────────────────
#  Taraa Backend — Environment Template
#  Copy to .env.development / .env.staging / .env.production
#  and fill in real values. Never commit files with secrets.
# ──────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ── MongoDB Atlas ──────────────────────────────────────
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# ── JWT ────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── Cloudinary ─────────────────────────────────────────
# https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay ───────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ for dev/staging, rzp_live_ for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# https://dashboard.razorpay.com → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=

# ── Firebase Admin SDK ─────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# These are DIFFERENT from the web client config below
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Firebase Web Client Config ─────────────────────────
# Firebase Console → Project Settings → Your apps → Web app → SDK setup
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── CORS ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
