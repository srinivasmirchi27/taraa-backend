# Application
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=taraa_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=taraa_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=taraa_db

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://taraa.in

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Admin
ADMIN_EMAIL=admin@taraa.in
ADMIN_PASSWORD=admin123
